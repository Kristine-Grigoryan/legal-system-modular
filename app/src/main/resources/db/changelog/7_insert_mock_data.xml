<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <!-- 1. USER -->
    <changeSet id="user-1" author="system">
        <insert tableName="users">
            <column name="id" valueNumeric="1"/>
            <column name="name" value="John"/>
            <column name="surname" value="Doe"/>
            <column name="username" value="john.doe@example.com"/>
            <column name="password" value="encoded_password_here"/>
            <column name="enabled" valueBoolean="true"/>
            <column name="role" value="USER"/>
        </insert>
    </changeSet>

    <!-- 2. LEGAL CASE -->
    <changeSet id="case-1" author="system">
        <insert tableName="legal_case">
            <column name="id" valueNumeric="1"/>
            <column name="title" value="Contract Dispute #101"/>
            <column name="description" value="Initial breach of contract investigation."/>
            <column name="amount" valueNumeric="1500.00"/>
            <column name="status" value="OPEN"/>
            <column name="user_id" valueNumeric="1"/>
        </insert>
    </changeSet>

    <!-- 3. COURT SESSION -->
    <changeSet id="session-1" author="system">
        <insert tableName="court_session">
            <column name="session_date" valueDate="2026-05-20"/>
            <column name="courtroom" value="Room 302B"/>
            <column name="notes" value="Pre-trial hearing for discovery."/>
            <column name="case_id" valueNumeric="1"/>
        </insert>
    </changeSet>

    <!-- 4. DOCUMENT -->
    <changeSet id="doc-1" author="system">
        <insert tableName="case_document">
            <column name="file_name" value="contract.pdf"/>
            <column name="file_type" value="application/pdf"/>
            <column name="file_path" value="/uploads/contract.pdf"/>
            <column name="case_id" valueNumeric="1"/>
        </insert>
    </changeSet>

    <!-- 5. PAYMENT -->
    <changeSet id="payment-1" author="system">
        <insert tableName="payment">
            <column name="amount" valueNumeric="1500.00"/>
            <column name="paid_date" valueDate="2026-03-10"/>
            <column name="method" value="BANK_TRANSFER"/>
            <column name="case_id" valueNumeric="1"/>
        </insert>
    </changeSet>

</databaseChangeLog>