    <changeSet id="insert-mock-legal-case-en" author="kgrigoryan">
        <insert tableName="legal_case">
            <column name="title" value="Employment Dispute #102"/>
            <column name="description" value="Case regarding unpaid vacation pay and overtime."/>
            <column name="status" value="OPEN"/>
            <column name="amount" valueNumeric="5500.00"/>
            <column name="user_id" valueNumeric="1"/>
        </insert>
        <insert tableName="legal_case">
            <column name="title" value="Property Rights Conflict"/>
            <column name="description" value="Dispute over residential property privatization."/>
            <column name="status" value="IN_PROGRESS"/>
            <column name="amount" valueNumeric="12500.00"/>
            <column name="user_id" valueNumeric="2"/>
        </insert>
    </changeSet>

    <changeSet id="insert-mock-court-session-en" author="kgrigoryan">
        <insert tableName="court_session">
            <!-- Validated: Future date for @FutureOrPresent constraint -->
            <column name="session_date" valueDate="2026-06-20T10:30:00"/>
            <!-- Validated: Under 20-150 chars for @Size constraint -->
            <column name="courtroom" value="Courtroom 4A - Civil"/>
            <!-- Validated: Short notes for @Size(max=50) if strictly followed -->
            <column name="notes" value="Preliminary hearing and witness testimony."/>
            <column name="case_id" valueNumeric="1"/>
        </insert>
    </changeSet>

    <changeSet id="insert-mock-document-en" author="kgrigoryan">
        <insert tableName="case_document">
            <column name="file_name" value="legal_claim_form.pdf"/>
            <column name="file_type" value="application/pdf"/>
            <column name="file_path" value="/uploads/cases/1/claim.pdf"/>
            <column name="uploaded_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="case_id" valueNumeric="1"/>
        </insert>
    </changeSet>


    <changeSet id="insert-mock-payment-en" author="kgrigoryan">
          <insert tableName="payment">
              <column name="amount" valueNumeric="1500.00"/>
              <column name="paid_date" valueDate="2026-03-10"/>
              <column name="method" value="BANK"/>
              <column name="case_id" valueNumeric="1"/>
          </insert>
    </changeSet>

</databaseChangeLog>